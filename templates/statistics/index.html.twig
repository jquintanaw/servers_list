{% extends 'base.html.twig' %}

{% block title %}Estadísticas{% endblock %}

{% block stylesheets %}
<style>
.stat-card {
    border-radius: 0.5rem;
}
.stat-number {
    font-size: 2.5rem;
    font-weight: 700;
}
.chart-container {
    position: relative;
    height: 300px;
}
.card-header h5 {
    margin: 0;
}
html[data-theme="dark"] .card-header h5,
html[data-theme="dark"] .h2,
html[data-theme="dark"] h2 {
    color: #fff !important;
}
html[data-theme="dark"] .stat-card.bg-warning .text-white {
    color: #fff !important;
}
</style>
{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="h4 mb-3">
            <i class="bi bi-bar-chart me-2"></i>Estadísticas de Servidores
        </h2>
    </div>
</div>

{# Summary Cards #}
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stat-card bg-primary text-white">
            <div class="card-body text-center">
                <i class="bi bi-hdd" style="font-size: 2rem;"></i>
                <div class="stat-number">{{ totalServers }}</div>
                <div>Total Servidores</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card bg-success text-white">
            <div class="card-body text-center">
                <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                <div class="stat-number">
                    {% for s in serversByStatus %}
                        {% if s.status == 'active' %}{{ s.count }}{% endif %}
                    {% endfor %}
                </div>
                <div>Activos</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card bg-warning text-dark" data-bs-theme="dark">
            <div class="card-body text-center text-white">
                <i class="bi bi-exclamation-triangle text-white" style="font-size: 2rem;"></i>
                <div class="stat-number text-white">
                    {% for s in serversByStatus %}
                        {% if s.status == 'maintenance' %}{{ s.count }}{% endif %}
                    {% endfor %}
                </div>
                <div class="text-white">Mantenimiento</div>
            </div>
        </div>
    </div>
</div>

{# Charts #}
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Sistemas Operativos</h5>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="osChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Estados</h5>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-tags me-2"></i>Tags Más Usados</h5>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="tagsChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    var textColor = isDark ? '#ffffff' : '#212529';
    
    // Apply globally BEFORE creating charts
    Chart.defaults.color = textColor;
    Chart.defaults.plugins.legend.labels.color = textColor;
    Chart.defaults.scale.grid.color = isDark ? '#444' : '#ddd';
    Chart.defaults.font.size = 12;

    var baseOptions = {
        responsive: true, 
        maintainAspectRatio: false,
        plugins: {
            legend: {
                labels: { color: textColor }
            }
        }
    };

    var osChart = new Chart(document.getElementById('osChart'), {
        type: 'doughnut',
        data: {
            labels: [{% for s in serversByOs %}'{{ s.osName }}',{% endfor %}],
            datasets: [{
                data: [{% for s in serversByOs %}{{ s.count }},{% endfor %}],
                backgroundColor: [
                    '#0d6efd', '#6610f2', '#6f42c1', '#d63384',
                    '#dc3545', '#fd7e14', '#ffc107', '#198754',
                    '#20c997', '#6c757d'
                ]
            }]
        },
        options: baseOptions
    });

    var statusChart = new Chart(document.getElementById('statusChart'), {
        type: 'pie',
        data: {
            labels: [{% for s in serversByStatus %}'{{ s.status|capitalize }}',{% endfor %}],
            datasets: [{
                data: [{% for s in serversByStatus %}{{ s.count }},{% endfor %}],
                backgroundColor: ['#198754', '#dc3545', '#ffc107']
            }]
        },
        options: baseOptions
    });

    var tagsChart = new Chart(document.getElementById('tagsChart'), {
        type: 'bar',
        data: {
            labels: [{% for name, count in tagsUsage %}'{{ name }}',{% endfor %}],
            datasets: [{
                label: 'Servidores',
                data: [{% for name, count in tagsUsage %}{{ count }},{% endfor %}],
                backgroundColor: '#0d6efd'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { labels: { color: textColor } }
            },
            scales: { 
                y: { beginAtZero: true, ticks: { stepSize: 1, color: textColor } },
                x: { ticks: { color: textColor } }
            }
        }
    });
});
</script>
{% endblock %}
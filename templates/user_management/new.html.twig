{% extends 'base.html.twig' %}

{% block title %}Nuevo Usuario - Panel de Control{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-plus me-2"></i>Nuevo Usuario</h2>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" id="user-form">
            <h5 class="border-bottom pb-2 mb-3">Datos de Acceso</h5>
            
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" required>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Contraseña</label>
                <input type="password" class="form-control" id="password" name="password" required minlength="6">
                <div class="form-text">Mínimo 6 caracteres</div>
            </div>

            <div class="mb-3">
                <label for="status" class="form-label">Estado</label>
                <select class="form-select" id="status" name="status">
                    <option value="enabled">Activo</option>
                    <option value="disabled">Deshabilitado</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="tenant" class="form-label">Cliente (Tenant)</label>
                <select class="form-select" id="tenant" name="tenant">
                    <option value="">Sin asignar</option>
                    {% if tenants is defined %}
                        {% for t in tenants %}
                            <option value="{{ t.id }}">{{ t.name }}</option>
                        {% endfor %}
                    {% endif %}
                </select>
                <small class="text-muted">Asignar usuario a un cliente</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Roles</label>
                <div class="border rounded p-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="ROLE_SERVICE_ADMIN" id="role_service_admin_new">
                        <label class="form-check-label" for="role_service_admin_new">ROLE_SERVICE_ADMIN</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="ROLE_TENANT_ADMIN" id="role_tenant_admin_new">
                        <label class="form-check-label" for="role_tenant_admin_new">ROLE_TENANT_ADMIN (Gestión de Clientes)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="ROLE_ADMIN" id="role_admin_new">
                        <label class="form-check-label" for="role_admin_new">ROLE_ADMIN</label>
                    </div>
                </div>
            </div>

            <h5 class="border-bottom pb-2 mb-3 text-dark-mode">Datos de Perfil</h5>

            <div class="mb-3">
                <label for="fullName" class="form-label text-dark-mode">Nombre completo</label>
                <input type="text" class="form-control text-dark-mode-input" id="fullName" name="fullName" maxlength="100">
            </div>

            <div class="mb-3">
                <label for="address" class="form-label text-dark-mode">Dirección</label>
                <input type="text" class="form-control text-dark-mode-input" id="address" name="address" maxlength="255">
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="city" class="form-label text-dark-mode">Ciudad</label>
                    <input type="text" class="form-control text-dark-mode-input" id="city" name="city" maxlength="100">
                </div>
                <div class="col-md-6 mb-3">
                    <label for="country" class="form-label text-dark-mode">País</label>
                    <input type="text" class="form-control text-dark-mode-input" id="country" name="country" maxlength="100">
                </div>
            </div>

            <h6 class="border-bottom pb-2 mb-3 mt-4 text-dark-mode">Redes Sociales</h6>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="social_twitter" class="form-label text-dark-mode">Twitter/X</label>
                    <div class="input-group">
                        <span class="input-group-text text-dark-mode">@</span>
                        <input type="text" class="form-control text-dark-mode-input" id="social_twitter" name="socialNetworks[twitter]" placeholder="usuario">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="social_github" class="form-label text-dark-mode">GitHub</label>
                    <input type="text" class="form-control text-dark-mode-input" id="social_github" name="socialNetworks[github]" placeholder="usuario">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="social_linkedin" class="form-label">LinkedIn</label>
                    <input type="text" class="form-control" id="social_linkedin" name="socialNetworks[linkedin]" placeholder="usuario">
                </div>
                <div class="col-md-6 mb-3">
                    <label for="social_website" class="form-label">Sitio Web</label>
                    <input type="url" class="form-control" id="social_website" name="socialNetworks[website]" placeholder="https://">
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Crear Usuario
                </button>
                <a href="{{ path('app_users') }}" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<script>
document.getElementById('user-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const data = {
        email: formData.get('email'),
        password: formData.get('password'),
        status: formData.get('status'),
        tenant: formData.get('tenant'),
        fullName: formData.get('fullName'),
        address: formData.get('address'),
        city: formData.get('city'),
        country: formData.get('country'),
        socialNetworks: {
            twitter: formData.get('socialNetworks[twitter]'),
            github: formData.get('socialNetworks[github]'),
            linkedin: formData.get('socialNetworks[linkedin]'),
            website: formData.get('socialNetworks[website]')
        }
    };

    fetch('{{ path('app_users_new') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.error) {
            alert(data.error);
        } else if (data.errors) {
            alert('Errores: ' + Object.values(data.errors).join(', '));
        } else {
            window.location.href = '{{ path('app_users') }}';
        }
    })
    .catch(error => {
        alert('Error al crear usuario');
    });
});
</script>
{% endblock %}
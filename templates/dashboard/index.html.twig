{% extends 'base.html.twig' %}

{% block title %}Panel de Control{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-4">
        <h2 class="h4">
            <i class="bi bi-speedometer2 me-2"></i>Bienvenido, {{ app.user.userIdentifier }}
        </h2>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-server" style="font-size: 3rem; color: #0d6efd;"></i>
                <h5 class="card-title mt-3">Servidores</h5>
                <p class="card-text text-muted">Gestiona los servidores del sistema</p>
                <a href="{{ path('app_servers') }}" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-right me-1"></i>Ver Servidores
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-house" style="font-size: 3rem; color: #198754;"></i>
                <h5 class="card-title mt-3">Inicio</h5>
                <p class="card-text text-muted">Volver a la página principal</p>
                <a href="{{ path('app_home') }}" class="btn btn-outline-success">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Inicio
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-box-arrow-right" style="font-size: 3rem; color: #dc3545;"></i>
                <h5 class="card-title mt-3">Sesión</h5>
                <p class="card-text text-muted">Cerrar sesión actual</p>
                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">
                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
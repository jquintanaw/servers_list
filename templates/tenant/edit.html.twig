{% extends 'base.html.twig' %}

{% block title %}Editar Cliente{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="h4 mb-3">
            <i class="bi bi-building me-2"></i>Editar Cliente
        </h2>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" class="row g-3">
            <div class="col-md-6">
                <label for="name" class="form-label">Nombre *</label>
                <input type="text" class="form-control" id="name" name="name" value="{{ tenant.name }}" required>
            </div>
            <div class="col-md-6">
                <label for="address" class="form-label">Dirección *</label>
                <input type="text" class="form-control" id="address" name="address" value="{{ tenant.address }}" required>
            </div>
            <div class="col-md-6">
                <label for="contractType" class="form-label">Tipo de Contrato</label>
                <input type="text" class="form-control" value="{{ tenant.contractType.name }}" disabled>
                <input type="hidden" name="contractType" value="{{ tenant.contractType.id }}">
                <small class="text-muted">No modificable una vez asignado</small>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a href="{{ path('app_tenants') }}" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
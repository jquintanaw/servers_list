{% extends 'base.html.twig' %}

{% block title %}Clientes{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="h4 mb-3">
            <i class="bi bi-building me-2"></i>Clientes
        </h2>
    </div>
    <div class="col-md-6 text-md-end">
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_tenants_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Nuevo Cliente
            </a>
        {% endif %}
    </div>
</div>

{% if app.flashes('success')|length > 0 %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}

{% if app.flashes('error')|length > 0 %}
    {% for flash in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Dirección</th>
                    <th>Tipo de Contrato</th>
                    <th>Servidores</th>
                    <th>Usuarios</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for tenant in tenants %}
                <tr>
                    <td>{{ tenant.name }}</td>
                    <td>{{ tenant.address }}</td>
                    <td>{{ tenant.contractType.name }}</td>
                    <td>{{ tenant.servers|length }}</td>
                    <td>{{ tenant.users|length }}</td>
                    <td class="text-end">
                        <a href="{{ path('app_tenants_edit', {id: tenant.id}) }}" class="btn btn-sm btn-outline-primary" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <form method="post" action="{{ path('app_tenants_delete', {id: tenant.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tenant.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="event.preventDefault(); confirmAction('¿Eliminar este cliente?', this.form)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        No hay clientes registrados.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
function confirmAction(message, form) {
    if (confirm(message)) {
        form.submit();
    }
}
</script>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Gestión de Tags{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="h4 mb-3">
            <i class="bi bi-tags me-2"></i>Gestión de Tags
        </h2>
    </div>
    <div class="col-md-6 text-md-end">
        <a href="{{ path('app_admin_tags_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Tag
        </a>
    </div>
</div>

{% if app.flashes('success')|length > 0 or app.flashes('error')|length > 0 %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for flash in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Color</th>
                    <th>Servidores</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for tag in tags %}
                <tr>
                    <td class="fw-semibold">{{ tag.name }}</td>
                    <td>
                        <span class="badge bg-{{ tag.color }}">{{ tag.color }}</span>
                    </td>
                    <td>
                        {% if tag.servers|length > 0 %}
                            <span class="badge bg-secondary">{{ tag.servers|length }}</span>
                        {% else %}
                            <span class="text-muted">0</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <a href="{{ path('app_admin_tags_edit', {id: tag.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if tag.servers|length == 0 %}
                            <form method="post" action="{{ path('app_admin_tags_delete', {id: tag.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_tag_' ~ tag.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Eliminar {{ tag.name }}?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        No hay tags registrados.
                        <br><a href="{{ path('app_admin_tags_new') }}">Crear el primero</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
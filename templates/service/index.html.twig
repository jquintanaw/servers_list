{% extends 'base.html.twig' %}

{% block title %}Servicios{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="h4 mb-3">
            <i class="bi bi-gear me-2"></i>Administración de Servicios
        </h2>
    </div>
    <div class="col-md-6 text-md-end">
        {% if is_granted('ROLE_SERVICE_ADMIN') %}
            <a href="{{ path('app_services_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Nuevo Servicio
            </a>
        {% endif %}
    </div>
</div>

{% if app.flashes('success')|length > 0 %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Servidores</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for service in services %}
                <tr>
                    <td class="fw-semibold">{{ service.name }}</td>
                    <td>{{ service.description }}</td>
                    <td>
                        {% if service.servers|length > 0 %}
                            <span class="badge bg-secondary">{{ service.servers|length }}</span>
                        {% else %}
                            <span class="text-muted">0</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        {% if is_granted('ROLE_SERVICE_ADMIN') %}
                            <a href="{{ path('app_services_edit', {id: service.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <button type="button" class="btn btn-sm btn-outline-danger" title="Eliminar" data-bs-toggle="modal" data-bs-target="#deleteModal{{ service.id }}">
                                <i class="bi bi-trash"></i>
                            </button>
                            <div class="modal fade" id="deleteModal{{ service.id }}" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Eliminar {{ service.name }}?</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p>¿Está seguro de eliminar este servicio?</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                            <form method="post" action="{{ path('app_services_delete', {id: service.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_service' ~ service.id) }}">
                                                <button type="submit" class="btn btn-danger">Eliminar</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        No hay servicios registrados.
                        {% if is_granted('ROLE_SERVICE_ADMIN') %}
                            <br><a href="{{ path('app_services_new') }}">Crear el primero</a>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
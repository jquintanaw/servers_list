{% extends 'base.html.twig' %}

{% block title %}Tipos de Contrato{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="h4 mb-3">
            <i class="bi bi-file-text me-2"></i>Tipos de Contrato
        </h2>
    </div>
    <div class="col-md-6 text-md-end">
        <a href="{{ path('app_contract_types_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Tipo
        </a>
    </div>
</div>

{% if app.flashes('success')|length > 0 %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}

{% if app.flashes('error')|length > 0 %}
    {% for flash in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ flash }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="text-end">Precio</th>
                    <th>Clientes</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for contractType in contractTypes %}
                <tr>
                    <td>{{ contractType.name }}</td>
                    <td>{{ contractType.description }}</td>
                    <td class="text-end">{{ contractType.price ? contractType.price ~ ' €' : '-' }}</td>
                    <td>{{ contractType.tenants|length }}</td>
                    <td class="text-end">
                        <a href="{{ path('app_contract_types_edit', {id: contractType.id}) }}" class="btn btn-sm btn-outline-primary" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('app_contract_types_delete', {id: contractType.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contractType.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="event.preventDefault(); confirmAction('¿Eliminar este tipo de contrato?', this.form)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        No hay tipos de contrato registrados.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
function confirmAction(message, form) {
    if (confirm(message)) {
        form.submit();
    }
}
</script>
{% endblock %}